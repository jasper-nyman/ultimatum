  - Extension: .cs
    TargetFolder: Assets/Scripts
  - Extension: .asset
    TargetFolder: Assets/Data
  - Extension: .png
    TargetFolder: Assets/Art/Textures
  - Extension: .jpg
    TargetFolder: Assets/Art/Textures
  - Extension: .jpeg
    TargetFolder: Assets/Art/Textures
  - Extension: .tga
    TargetFolder: Assets/Art/Textures
  - Extension: .psd
    TargetFolder: Assets/Art/Textures
  - Extension: .fbx
    TargetFolder: Assets/Art/Models
  - Extension: .mat
    TargetFolder: Assets/Art/Materials
  - Extension: .shader
