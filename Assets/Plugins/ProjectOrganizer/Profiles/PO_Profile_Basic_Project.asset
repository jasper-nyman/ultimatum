  ExtensionsToScan: .unity,.prefab,.cs,.asset,.png,.jpg,.jpeg,.tga,.psd,.fbx,.wav,.mp3,.ogg,.mat,.shader,.shadergraph,.controller,.anim,.overridecontroller,.mp4,.txt,.json,.bytes
